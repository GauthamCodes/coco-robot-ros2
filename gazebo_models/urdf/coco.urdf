    <inertial>
      <origin xyz="-0.12 0.030342 -0.08" rpy="0 0 0"/>
      <mass value="1.041325"/>
      <inertia 
        ixx="0.003717" ixy="7.105E-19"  ixz="-7.105E-18"
        iyy="0.008246" iyz="1.066E-18"
        izz="0.005625"/>
    </inertial>
  </link>

  <!-- Wheels -->
  <!-- wheel1 -->
  
  <link name="wheel1">
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>

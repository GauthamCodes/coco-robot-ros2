               iyy="1.8549E-8" iyz="1.34E-10" izz="0.00769"/>
    </inertial>
  </link>

  <!-- Revolute joint between base and wheel1 -->
  <joint name="base_to_wheel1" type="revolute">
    <parent link="base"/>
    <child link="wheel1"/>
    <origin xyz="-0.03 0.045 0.043181 " rpy="0 0 0"/>
    <axis xyz="0 1 0" />
    <limit effort="1" velocity="10" lower="-3.14" upper="3.14"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- wheel2 -->

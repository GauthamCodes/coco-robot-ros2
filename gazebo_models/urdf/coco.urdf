<?xml version="1.0"?>
<robot name="coco">

  <!-- Base Link -->
  <link name="base">
  
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/gautham/ros2_ws/src/gazebo_models/meshes/base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
